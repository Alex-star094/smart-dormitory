/* app.wxss */
/* 全局样式重置和基础样式 */

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', STHeiti, 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 按钮基础样式 */
.btn {
  margin: 10rpx;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.btn-primary {
  background-color: #007bff;
  color: white;
}

.btn-primary:active {
  background-color: #0056b3;
  transform: scale(0.98);
}

.btn-danger {
  background-color: #dc3545;
  color: white;
}

.btn-danger:active {
  background-color: #bd2130;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #6c757d;
  color: white;
}

.btn-secondary:active {
  background-color: #545b62;
  transform: scale(0.98);
}

.btn-success {
  background-color: #28a745;
  color: white;
}

.btn-success:active {
  background-color: #1e7e34;
  transform: scale(0.98);
}

/* 卡片组件样式 */
.card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 文字对齐样式 */
.text-center {
  text-align: center;
}

.text-muted {
  color: #6c757d;
}

/* 表单元素基础样式 */
.input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: white;
}

.input:focus {
  border-color: #007bff;
  box-shadow: 0 0 0 2rpx rgba(0, 123, 255, 0.25);
}

.textarea {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: white;
  min-height: 120rpx;
}

.textarea:focus {
  border-color: #007bff;
  box-shadow: 0 0 0 2rpx rgba(0, 123, 255, 0.25);
}

/* 消息提示样式 */
.message {
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
  margin: 20rpx 0;
}

.message.success {
  background-color: #d4edda;
  color: #155724;
  border: 1rpx solid #c3e6cb;
}

.message.error {
  background-color: #f8d7da;
  color: #721c24;
  border: 1rpx solid #f5c6cb;
}

.message.info {
  background-color: #d1ecf1;
  color: #0c5460;
  border: 1rpx solid #bee5eb;
}
