/* pages/register/register.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f9fa;
  min-height: 100vh;
}

.card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #007bff;
  display: block;
  text-align: center;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6c757d;
  display: block;
  text-align: center;
}

.input-group {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
}

.label {
  font-size: 32rpx;
  margin-right: 20rpx;
  min-width: 120rpx;
}

.input {
  flex: 1;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

.camera-container {
  position: relative;
  width: 100%;
  height: 500rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.camera {
  width: 100%;
  height: 100%;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
}

.countdown {
  font-size: 60rpx;
  font-weight: bold;
  color: white;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.8);
}

.instructions {
  font-size: 32rpx;
  color: white;
  text-align: center;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.8);
}

.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  border: none;
  font-size: 32rpx;
  margin: 10rpx 0;
}

.btn-primary {
  background: #007bff;
  color: white;
}

.btn-secondary {
  background: #6c757d;
  color: white;
}

.btn:disabled {
  background: #ccc;
  color: #666;
}

.message {
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  text-align: center;
}

.message.success {
  background: #d4edda;
  color: #155724;
  border: 1rpx solid #c3e6cb;
}

.message.error {
  background: #f8d7da;
  color: #721c24;
  border: 1rpx solid #f5c6cb;
}

.message.info {
  background: #d1ecf1;
  color: #0c5460;
  border: 1rpx solid #bee5eb;
}
