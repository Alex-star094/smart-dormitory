/* pages/more/more.wxss */
page { background: #f5f7fa; }
.container { padding: 20rpx 24rpx 40rpx; }

/* ---- 未登录 ---- */
.login-card { text-align: center; padding: 120rpx 40rpx; }
.login-icon { font-size: 60rpx; display: block; margin-bottom: 20rpx; }
.login-text { font-size: 28rpx; color: #999; display: block; margin-bottom: 30rpx; }
.btn-go {
  background: #4361ee; color: #fff; border: none;
  padding: 16rpx 50rpx; border-radius: 40rpx; font-size: 28rpx;
}

/* ---- 分区 ---- */
.section { background: #fff; border-radius: 16rpx; margin-bottom: 20rpx; overflow: hidden; }
.section-title {
  font-size: 26rpx; color: #999; padding: 24rpx 24rpx 12rpx;
}

/* ---- 菜单行 ---- */
.menu-list { }
.menu-row {
  display: flex; align-items: center; padding: 28rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}
.menu-row:active { background: #f8f9fa; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; flex-shrink: 0; }
.menu-label { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 32rpx; color: #ccc; }

/* ---- 退出 ---- */
.logout-box { padding: 30rpx 0; }
.btn-logout {
  width: 100%; background: #fff; color: #e74c3c; border: 1rpx solid #ffdddd;
  padding: 24rpx; border-radius: 12rpx; font-size: 28rpx;
}

/* ---- 版本 ---- */
.version { text-align: center; padding: 40rpx 0; font-size: 22rpx; color: #bbb; }
