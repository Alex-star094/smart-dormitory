<!--pages/more/more.wxml - 系统菜单-->
<view class="container">

  <!-- 未登录 -->
  <view wx:if="{{!isLoggedIn}}" class="login-card">
    <text class="login-icon">🔐</text>
    <text class="login-text">尚未登录</text>
    <button class="btn-go" bindtap="goToLogin">去登录</button>
  </view>

  <!-- 已登录 -->
  <block wx:if="{{isLoggedIn}}">

    <!-- 功能区 -->
    <view class="section">
      <view class="section-title">常用功能</view>
      <view class="menu-list">
        <view class="menu-row" bindtap="goToEnergy">
          <text class="menu-icon">⚡</text>
          <text class="menu-label">能耗统计</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-row" bindtap="goToRepair">
          <text class="menu-icon">🔧</text>
          <text class="menu-label">维修管理</text>
          <text class="menu-arrow">›</text>
        </view>
        <view wx:if="{{isAdmin}}" class="menu-row" bindtap="goToManage">
          <text class="menu-icon">⚙️</text>
          <text class="menu-label">系统管理</text>
          <text class="menu-arrow">›</text>
        </view>
        <view wx:if="{{isAdmin}}" class="menu-row" bindtap="goToRegister">
          <text class="menu-icon">📷</text>
          <text class="menu-label">人脸录入</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 系统 -->
    <view class="section">
      <view class="section-title">系统</view>
      <view class="menu-list">
        <view class="menu-row" bindtap="goToAbout">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-label">关于系统</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-row" bindtap="clearCache">
          <text class="menu-icon">🗑️</text>
          <text class="menu-label">清除缓存</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出 -->
    <view class="logout-box">
      <button class="btn-logout" bindtap="logout">退出登录</button>
    </view>

    <!-- 版本 -->
    <view class="version">智安校园 v2.0 · 宿舍智能管理系统</view>

  </block>
</view>
