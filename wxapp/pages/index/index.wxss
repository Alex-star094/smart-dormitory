/* pages/index/index.wxss - 仪表盘样式 */
page { background: #f5f7fa; }

.container { padding: 20rpx 24rpx 40rpx; }

/* ---- 未登录 ---- */
.login-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 40rpx; text-align: center;
}
.login-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.login-title { font-size: 40rpx; font-weight: bold; color: #333; }
.login-sub { font-size: 26rpx; color: #999; margin: 12rpx 0 40rpx; }
.btn-primary {
  background: #4361ee; color: #fff; border: none;
  padding: 20rpx 60rpx; border-radius: 40rpx; font-size: 28rpx;
}

/* ---- 用户条 ---- */
.user-bar {
  display: flex; align-items: center; background: #fff;
  padding: 24rpx; border-radius: 16rpx; margin-bottom: 20rpx;
}
.user-avatar {
  width: 72rpx; height: 72rpx; border-radius: 36rpx;
  background: #4361ee; color: #fff; font-size: 32rpx; font-weight: bold;
  display: flex; align-items: center; justify-content: center; margin-right: 20rpx;
}
.user-info { flex: 1; }
.user-name { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.user-dorm { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.user-badge {
  background: #f0f4ff; color: #4361ee; font-size: 22rpx;
  padding: 6rpx 16rpx; border-radius: 20rpx;
}

/* ---- 统计卡片 ---- */
.stats-row {
  display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 20rpx;
}
.stat-card {
  flex: 1; min-width: 150rpx; background: #fff;
  padding: 24rpx; border-radius: 16rpx; text-align: center;
}
.stat-card.warn { background: #fff8e6; }
.stat-num { font-size: 44rpx; font-weight: bold; color: #4361ee; display: block; }
.stat-num.red { color: #e74c3c; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }

/* ---- 通用分区 ---- */
.section {
  background: #fff; border-radius: 16rpx; padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 28rpx; font-weight: bold; color: #333;
  margin-bottom: 20rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f0f0f0;
}

/* ---- 待办 ---- */
.todo-item {
  display: flex; align-items: center; padding: 12rpx 0;
  font-size: 26rpx; color: #555;
}
.todo-dot {
  width: 12rpx; height: 12rpx; border-radius: 6rpx;
  background: #ffc107; margin-right: 16rpx; flex-shrink: 0;
}
.todo-dot.urgent { background: #e74c3c; }

/* ---- 能耗 ---- */
.energy-row { display: flex; gap: 20rpx; }
.energy-card {
  flex: 1; padding: 24rpx; border-radius: 12rpx; text-align: center;
}
.energy-card.elec { background: #fff7e6; }
.energy-card.water { background: #e6f7ff; }
.energy-val { font-size: 32rpx; font-weight: bold; color: #333; display: block; }
.energy-cost { font-size: 24rpx; color: #666; margin-top: 6rpx; display: block; }
.energy-tag {
  display: inline-block; background: #e74c3c; color: #fff; font-size: 20rpx;
  padding: 4rpx 12rpx; border-radius: 10rpx; margin-top: 8rpx;
}

/* ---- 通行摘要 ---- */
.access-summary { font-size: 26rpx; color: #555; padding: 12rpx 0; }
.access-status { margin-left: 12rpx; font-weight: bold; }
.access-status.allowed { color: #27ae60; }
.access-status.denied { color: #e74c3c; }

/* ---- 快捷入口 ---- */
.quick-grid {
  display: flex; flex-wrap: wrap; gap: 0;
}
.quick-item {
  width: 25%; display: flex; flex-direction: column;
  align-items: center; padding: 24rpx 0;
}
.quick-item:active { opacity: 0.6; }
.quick-icon { font-size: 44rpx; margin-bottom: 10rpx; }
.quick-text { font-size: 22rpx; color: #666; }

/* ---- 公告 ---- */
.notice-item {
  display: flex; align-items: center; padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.notice-item:last-child { border-bottom: none; }
.notice-tag {
  font-size: 28rpx; margin-right: 16rpx; flex-shrink: 0;
  width: 48rpx; text-align: center;
}
.notice-body { flex: 1; }
.notice-title { font-size: 26rpx; color: #333; display: block; }
.notice-time { font-size: 22rpx; color: #bbb; margin-top: 4rpx; display: block; }

/* ---- 加载 ---- */
.loading-box { text-align: center; padding: 100rpx; color: #999; font-size: 28rpx; }
