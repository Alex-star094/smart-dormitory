/* pages/energy/energy.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.btn-refresh {
  font-size: 24rpx;
  color: #007bff;
  background-color: transparent;
  border: none;
  padding: 10rpx 20rpx;
}

.stats-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stat-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666666;
  min-width: 120rpx;
}

.value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
  text-align: right;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  margin-top: 10rpx;
}

.btn {
  padding: 24rpx 48rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
  margin: 10rpx;
  min-width: 160rpx;
}

.btn-primary {
  background-color: #007bff;
  color: white;
}

.btn-primary:disabled {
  background-color: #cccccc;
  color: #666666;
}

.btn:disabled {
  opacity: 0.6;
}

.message {
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.message.success {
  background-color: #d4edda;
  color: #155724;
  border: 1rpx solid #c3e6cb;
}

.message.error {
  background-color: #f8d7da;
  color: #721c24;
  border: 1rpx solid #f5c6cb;
}

/* 搜索栏样式 */
.search-container {
  display: flex;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.search-input {
  flex: 1;
  padding: 20rpx;
  background: white;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-search {
  margin-left: 20rpx;
  background: #4CAF50;
  color: white;
  border-radius: 8rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  line-height: 70rpx;
}

/* 筛选组 */
.filter-group {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.filter-picker {
  flex: 1;
  background: white;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.month-input {
  flex: 1;
  padding: 20rpx;
  background: white;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 能耗列表样式 */
.energy-list {
  margin-top: 20rpx;
}

.energy-item {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #4CAF50;
}

.energy-item.electricity {
  border-left-color: #FF9800;
}

.energy-item.water {
  border-left-color: #2196F3;
}

.energy-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.dormitory {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.energy-type {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #e8f5e9;
  color: #4CAF50;
}

.energy-type.electricity {
  background: #fff3e0;
  color: #FF9800;
}

.energy-type.water {
  background: #e3f2fd;
  color: #2196F3;
}

.energy-details {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.detail-item {
  flex: 1;
  min-width: 200rpx;
}

.detail-item .label {
  font-size: 24rpx;
  color: #666;
}

.detail-item .value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 告警警告样式 */
.alarm-warning {
  background: #fff2f2;
  border: 1rpx solid #ffcccc;
  border-radius: 8rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.alarm-icon {
  margin-right: 10rpx;
  font-size: 32rpx;
}

.alarm-text {
  flex: 1;
  color: #ff4444;
  font-size: 26rpx;
}

.alarm-time {
  font-size: 22rpx;
  color: #999;
}

/* 管理员操作按钮 */
.admin-actions {
  margin-top: 20rpx;
  text-align: right;
}

.btn-alarm {
  background: #ff9800;
  color: white;
  border-radius: 6rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
}

.btn-load-more {
  background: transparent;
  color: #4CAF50;
  border: 1rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.no-data {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}