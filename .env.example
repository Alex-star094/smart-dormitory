# ================================
# 智安校园 - 宿舍智能管理系统 环境配置模板
# 复制此文件为 .env 并填写真实值
# cp .env.example .env
# ================================

# 数据库配置
# DATABASE_TYPE 可选值: sqlite（本地开发） | mysql（生产环境）
DATABASE_TYPE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your-database-password-here
DB_NAME=smart_dorm

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
DB_POOL_PRE_PING=True

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT配置（生产环境请使用强随机密钥！）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-strong-secret-key-at-least-32-bytes-long
ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# 微信小程序配置
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret

# 业务配置
ELECTRICITY_ALARM_THRESHOLD=50.0
WATER_ALARM_THRESHOLD=10.0
FACE_MATCH_THRESHOLD=0.6

# 水电单价配置
ELECTRICITY_PRICE=0.667
WATER_PRICE=4.05
